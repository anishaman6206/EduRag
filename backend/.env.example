# ─────────────────────────────────────────────────────────────────────────
# EduRag .env.example
# Copy to .env (which is gitignored) and fill in your real values.
# ─────────────────────────────────────────────────────────────────────────

# OpenAI — used for BOTH text completions (gpt-4o-mini) and embeddings
OPENAI_API_KEY=
OPENAI_TEXT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Pinecone
PINECONE_API_KEY=
PINECONE_INDEX_NAME=edurag

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Redis
REDIS_URL=redis://localhost:6379

# Cohere (optional — reranking skipped if not set)
COHERE_API_KEY=

# Dev mode (currently a no-op; gpt-4o-mini is used in both dev and prod)
# Flip to false in production when you upgrade to a more capable model.
DEV_MODE=true
