# ─────────────────────────────────────────────────────────────────────────
# EduRag .env.example
# Copy to .env (which is gitignored) and fill in your real values.
# ─────────────────────────────────────────────────────────────────────────

# OpenAI — used for BOTH text completions (gpt-4o-mini) and embeddings
OPENAI_API_KEY=
OPENAI_TEXT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Pinecone
PINECONE_API_KEY=
PINECONE_INDEX_NAME=edurag

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Redis
REDIS_URL=redis://localhost:6379

# Cohere (optional — reranking skipped if not set)
COHERE_API_KEY=

# Rate limit on /ask — requests per minute per user (or per IP for
# anonymous). Set to 0 to disable. Fail-open if Redis is down.
ASK_RATE_LIMIT_PER_MINUTE=30

# CORS — comma-separated list of allowed origins. Defaults work for
# local dev. In production, set this to your real frontend domain(s):
#   CORS_ALLOWED_ORIGINS=https://edurag.vercel.app
# Never use "*" — we send credentials, which the browser rejects with
# a wildcard origin.
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Dev mode (currently a no-op; gpt-4o-mini is used in both dev and prod)
# Flip to false in production when you upgrade to a more capable model.
# When DEV_MODE=false, settings.MODELS uses _PROD_MODELS instead of
# _DEV_MODELS — currently identical, but you can change _PROD_MODELS in
# backend/config/settings.py to point at gpt-4o for higher quality
# answers without touching any other code.
DEV_MODE=true
