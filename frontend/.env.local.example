# ─────────────────────────────────────────────────────────────────────────
# EduRag frontend .env.local (copy to .env.local, fill in real values)
# ─────────────────────────────────────────────────────────────────────────

# Backend URL — used by next.config.js rewrites. In dev this is the
# FastAPI uvicorn server. In production it's the deployed URL.
BACKEND_URL=http://localhost:8000

# Supabase — used by the @supabase/ssr client for auth (email + Google).
# These are PUBLIC values (safe to expose to the browser) — Supabase
# Row Level Security is what protects the data.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Google OAuth — set to "false" to hide the Google sign-in button
# without redeploying. Default is enabled. The Supabase Google
# provider must also be configured in the Supabase dashboard for
# this to work.
NEXT_PUBLIC_GOOGLE_AUTH_ENABLED=true
